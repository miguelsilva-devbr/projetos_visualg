algoritmo "Valores entre 2 valores"
// Autor : Miguel Silva
// Data : 27/03/2026
var
v1, v2:inteiro
inicio
Escreval("digite o Primeiro Valor: ")
leia(v1)
Escreval("digite o Segundo Valor: ")
leia(v2)
Escreval("os valores somados sao: ",v1+v2)
  repita
  v1 := v1+1
  Escreval(v1)
  ate (v1=v2)
fimalgoritmo

