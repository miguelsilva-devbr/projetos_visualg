algoritmo "SomaProcedimentos"
// Função :
// Autor : Miguel Silva
// Data : 25/03/2026
// Seção de Declarações
var
X, Y: inteiro
Procedimento soma(A, B: inteiro)
inicio
Escreval("Recebi o valor: ", A)
Escreval("Recebi o valor: ", B)
Escreval("O valor da soma entre os dois e ", A+B)
FimProcedimento
inicio
X <- 10
Y <- 7
soma(X,Y)
fimalgoritmo
