algoritmo "Calculo_idade"
// Autor : Miguel Silva
// Data : 27/03/2026
var
 anonasc, anoatual, idade: inteiro
inicio
Escreval("Digite o ano do seu nascimento: ")
leia(anonasc)

Anoatual := 2026

idade := anoatual - anonasc

Escreval("Neste ano a idade que voce fara e: ", idade, "anos")
Escreval("Os dias de vida que voce completa sao: ", idade*365,25)
fimalgoritmo
